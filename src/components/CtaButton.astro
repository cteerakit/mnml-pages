---
import { siteConfig } from '../config/site';
import ChromeWebStoreIcon from './ChromeWebStoreIcon.astro';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
const isPlaceholder = siteConfig.chromeStoreUrl === '#';
---

<a
  href={siteConfig.chromeStoreUrl}
  class:list={[
    'inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground no-underline transition-opacity hover:opacity-90 hover:no-underline',
    className,
  ]}
  aria-label="Add mnml to Chrome from the Chrome Web Store"
  {...(isPlaceholder ? {} : { rel: 'noopener noreferrer', target: '_blank' })}
>
  <ChromeWebStoreIcon />
  Add to Chrome
</a>
