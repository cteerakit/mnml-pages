---
import { siteConfig } from '../config/site';
import CtaButton from './CtaButton.astro';
---

<header class="sticky top-0 z-50 border-b border-border bg-background/90 backdrop-blur-sm">
  <div class="mx-auto flex h-14 max-w-5xl items-center justify-between gap-4 px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2.5 no-underline hover:no-underline">
      <img
        src="/icon/32.png"
        alt=""
        width={32}
        height={32}
        class="size-8 rounded-md"
      />
      <span class="text-sm font-semibold tracking-tight">{siteConfig.name}</span>
    </a>
    <CtaButton />
  </div>
</header>
