---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = await getCollection('privacy');
const entry = entries.find((e) => e.id.endsWith('policy')) ?? entries[0];
if (!entry) {
  throw new Error('Privacy policy content not found');
}

const { Content } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  path="/privacy"
  ogType="article"
>
  <article class="prose-mnml mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16">
    <header class="border-b border-border pb-8">
      <h1 class="text-3xl font-semibold tracking-tight">{entry.data.title}</h1>
      <p class="mt-2 text-sm text-muted-foreground">
        Last updated: {entry.data.lastUpdated}
      </p>
    </header>
    <div class="mt-8">
      <Content />
    </div>
  </article>
</BaseLayout>
